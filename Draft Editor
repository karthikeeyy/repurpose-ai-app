<script>
        function switchPlatform(platform) {
            const tabs = document.querySelectorAll('.platform-tab');
            tabs.forEach(tab => {
                tab.classList.remove('active-tab');
                tab.classList.add('text-on-surface-variant');
                tab.classList.remove('text-secondary');
            });

            const activeTab = document.getElementById(`tab-${platform}`);
            activeTab.classList.add('active-tab');
            activeTab.classList.remove('text-on-surface-variant');

            // Simulate content change
            const editor = document.getElementById('editor-field');
            if(platform === 'twitter') {
                editor.innerHTML = `<p>The AI shift isn't coming—it's already here. 🧵<br><br>3 critical shifts creators need to know for 2024:<br><br>1/ Semantic Intent > Keywords<br>2/ Context > Copy-Paste<br>3/ Strategy > Generation<br><br>Full breakdown below 👇</p>`;
            } else if(platform === 'newsletter') {
                editor.innerHTML = `<h3>The Strategic Repurposing Playbook</h3><p>Hi everyone,</p><p>We talk a lot about AI tools, but we rarely talk about AI strategy...</p>`;
            } else {
                editor.innerHTML = `<p><strong>The AI shift isn't coming—it's already here.</strong></p><p>Most creators think about AI as a tool for generation...</p>`;
            }
        }

        function copyContent() {
            const content = document.getElementById('editor-field').innerText;
            navigator.clipboard.writeText(content).then(() => {
                const copyBtn = event.currentTarget;
                const originalContent = copyBtn.innerHTML;
                copyBtn.innerHTML = `<span class="material-symbols-outlined text-sm">check</span> Copied!`;
                setTimeout(() => {
                    copyBtn.innerHTML = originalContent;
                }, 2000);
            });
        }

        // Initialize micro-interactions
        document.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('mousedown', () => {
                btn.style.transform = 'scale(0.95)';
            });
            btn.addEventListener('mouseup', () => {
                btn.style.transform = 'scale(1)';
            });
            btn.addEventListener('mouseleave', () => {
                btn.style.transform = 'scale(1)';
            });
        });
    </script>
